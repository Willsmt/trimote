# Copie para .env e preencha. O .env NUNCA é commitado (Princípio I).

# PostgreSQL (corresponde ao docker-compose.yml local)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/trimote?schema=public"

# Conexão DIRETA p/ migrations. Em produção (Neon) o runtime usa a pooled
# (DATABASE_URL com -pooler) e o `migrate deploy` do build usa esta (host sem
# -pooler) — o schema engine usa advisory lock, incompatível com PgBouncer em
# transaction mode. No local não há pooler: as duas apontam pro mesmo docker :5433.
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/trimote?schema=public"

# NextAuth / Auth.js
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Google Cloud Console) — apenas via env, nunca no código
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Painel do dono (feature 002): e-mail do dono. O seed promove (ou cria) este usuário como OWNER.
# Use o e-mail Google com que você fará login; ao logar, o usuário real casa por e-mail.
OWNER_EMAIL="owner@example.com"
