// Schema Prisma — feature 001-barber-booking.
// Convenções: objetos de banco e código em inglês (Princípio V).
// Tempo: todos os instantes em UTC via Timestamptz (Princípio VII); o cálculo em
// America/Sao_Paulo é responsabilidade da camada de domínio, não do banco.
//
// IMPORTANTE: a garantia de não-sobreposição (Princípio II / FR-008/FR-009) é uma
// exclusion constraint (EXCLUDE USING gist sobre tstzrange) que o Prisma NÃO modela.
// Ela é adicionada por migration SQL manual — ver prisma/migrations e research.md (D1/D8).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Autenticação (NextAuth / Auth.js — Prisma adapter)
// ---------------------------------------------------------------------------

// Papel de PLATAFORMA do usuário. CLIENT default; ADMIN (F007) opera a plataforma (cria negócios,
// promove donos). OWNER permanece por custo de migração (Postgres não remove valor de enum), mas
// DEIXA de ser autoridade: a posse de negócio vive em BusinessMember (F007, research D4).
enum Role {
  CLIENT
  OWNER
  ADMIN
}

// Papel do vínculo dono↔negócio (F007). Nasce só com OWNER; STAFF é aditivo no futuro (fora de escopo).
enum BusinessRole {
  OWNER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT)
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  // Financeiro (005): dois papéis distintos num lançamento — cliente e autor (OWNER).
  ledgerEntriesAsClient LedgerEntry[] @relation("LedgerClient")
  ledgerEntriesCreated  LedgerEntry[] @relation("LedgerCreatedBy")
  // Multi-tenancy (007): vínculos dono↔negócio deste usuário, e vínculos que ele promoveu (auditoria).
  memberships        BusinessMember[] @relation("Membership")
  membershipsCreated BusinessMember[] @relation("MembershipCreatedBy")
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  // Multi-tenancy (007): negócio ATIVO do dono, estado server-side (nunca do input — anti-IDOR).
  // Revalidado por request (é membro OWNER?). SetNull se o negócio for removido.
  activeBusinessId String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeBusiness Business? @relation(fields: [activeBusinessId], references: [id], onDelete: SetNull)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domínio da barbearia
// ---------------------------------------------------------------------------

model Business {
  id        String              @id @default(cuid())
  name      String
  // Slug único e URL-safe (F007): porta pública em /b/[slug]. Imutável pela UI no MVP.
  slug      String              @unique
  // Fuso usado pela camada de domínio para derivar disponibilidade (default America/Sao_Paulo).
  timezone  String              @default("America/Sao_Paulo")
  // Vertical do negocio (F007). Sem ramificacao de comportamento no MVP (multi-vertical fora de escopo).
  segment   String              @default("barbershop")
  openingHours OpeningHours[]
  services  Service[]
  bookings  Booking[]
  ledgerEntries LedgerEntry[]
  // Multi-tenancy (007): membros (donos) e sessões com este negócio ativo.
  members       BusinessMember[]
  activeSessions Session[]
  // Auditoria da criação (F007): quem (ADMIN) e quando. Nullable p/ o negócio de backfill.
  createdBy String?
  createdAt DateTime            @default(now()) @db.Timestamptz(6)
}

// Vínculo N:N dono↔negócio (007). Fonte de verdade da posse (requireOwner consulta aqui). Unicidade
// (userId, businessId) torna vínculo duplicado impossível no dado (Princípio II). Duas FKs p/ User:
// o membro (userId) e quem promoveu (createdBy) — relations nomeadas (mesmo cuidado da F005).
model BusinessMember {
  id         String       @id @default(cuid())
  userId     String
  businessId String
  role       BusinessRole @default(OWNER)
  createdAt  DateTime     @default(now()) @db.Timestamptz(6)
  createdBy  String

  user     User     @relation("Membership", fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator  User     @relation("MembershipCreatedBy", fields: [createdBy], references: [id])

  @@unique([userId, businessId])
}

model OpeningHours {
  id           String     @id @default(cuid())
  businessId String
  // 0 = domingo ... 6 = sábado.
  weekday      Int
  // Horário local de abertura/fechamento, em minutos desde a meia-noite no fuso da barbearia
  // (ex.: 09:00 = 540, 18:00 = 1080). Evita ambiguidade de fuso ao representar hora local.
  opensAtMinutes  Int
  closesAtMinutes Int

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Uma janela contínua por dia no MVP.
  @@unique([businessId, weekday])
}

model Service {
  id              String    @id @default(cuid())
  businessId    String
  name            String
  // Preço monetário: NUMERIC, nunca float (Princípio II — precisão).
  price           Decimal   @db.Decimal(10, 2)
  durationMinutes Int
  // Soft delete (feature 002): desativar em vez de apagar, preservando histórico e agendamentos.
  // Unicidade de nome entre ativos é garantida por índice único parcial (migration SQL manual).
  isActive        Boolean   @default(true)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  // Financeiro (005): itens de lançamento que referenciam este serviço (snapshot de preço).
  ledgerItems LedgerEntryItem[]
}

enum BookingStatus {
  ACTIVE
  CANCELLED
  // 005-financial-ledger: estado terminal. Ao concluir, gera o lançamento de receita (US1).
  // Aditivo: sai naturalmente do índice parcial booking_no_overlap (WHERE status='ACTIVE').
  COMPLETED
}

model Booking {
  id           String        @id @default(cuid())
  businessId String
  userId       String
  serviceId    String
  // Instantes em UTC. endsAt é materializado (= startsAt + durationMinutes) na criação,
  // dentro da transação, para alimentar a exclusion constraint (research.md D8).
  startsAt     DateTime      @db.Timestamptz(6)
  endsAt       DateTime      @db.Timestamptz(6)
  status       BookingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  cancelledAt  DateTime?     @db.Timestamptz(6)

  business Business        @relation(fields: [businessId], references: [id])
  user       User              @relation(fields: [userId], references: [id])
  service    Service @relation(fields: [serviceId], references: [id])
  // Financeiro (005): bookingId nullable e SEM unicidade — um booking pode ter 1 lançamento ativo
  // + N inativados por soft delete (correção). Ver data-model.md D10.
  ledgerEntries LedgerEntry[]

  @@index([userId])
  @@index([businessId, status])
}

// ---------------------------------------------------------------------------
// Financeiro — captura de lançamentos (005-financial-ledger)
// ---------------------------------------------------------------------------

// Natureza do lançamento: entrada ou saída. O sinal do balancete vem daqui, NÃO do valor
// (amount é sempre positivo — FR-011).
enum LedgerType {
  INCOME
  EXPENSE
}

// Evento que originou o lançamento. Ortogonal a PaymentMethod (evento != meio — FR-012).
enum LedgerOrigin {
  BOOKING
  WALK_IN
  EXPENSE
}

// Meio de pagamento (opcional, informativo). ONLINE/externalRef preparam pagamento online futuro
// (FR-013), sem fluxo ativo nesta feature.
enum PaymentMethod {
  CASH
  PIX
  CARD
  ONLINE
  OTHER
}

// Uma linha do razão financeiro (entrada ou saída). amount sempre positivo; para receita é a soma
// dos itens (validada na aplicação, dentro da transação — FR-007), para despesa é informado direto.
model LedgerEntry {
  id           String        @id @default(cuid())
  businessId String
  type         LedgerType
  origin       LedgerOrigin
  // Valor monetário: NUMERIC, nunca float (Princípio II). Sempre > 0 (FR-011).
  amount       Decimal       @db.Decimal(10, 2)
  // Instante da captura (FR-017) — informado, NÃO derivado do endsAt do booking. UTC (Princípio VII).
  occurredAt   DateTime      @db.Timestamptz(6)
  description  String
  category     String?
  paymentMethod PaymentMethod?
  externalRef  String?
  bookingId    String?
  clientId     String?
  clientName   String?
  createdBy    String
  // Soft delete (FR-015): correção = inativar o lançamento inteiro, nunca hard delete nem estorno.
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking    Booking?           @relation(fields: [bookingId], references: [id])
  client     User?              @relation("LedgerClient", fields: [clientId], references: [id])
  creator    User               @relation("LedgerCreatedBy", fields: [createdBy], references: [id])
  items      LedgerEntryItem[]

  // Ajuda a agregação por barbearia/período da F006 (data-model.md D8/item 13).
  @@index([businessId, occurredAt])
}

// Line item de um lançamento de receita (serviço agendado ou extra). A soma dos itens deve bater
// com LedgerEntry.amount (FR-007). serviceId nullable: extra manual sem serviço (US2).
model LedgerEntryItem {
  id            String  @id @default(cuid())
  ledgerEntryId String
  serviceId     String?
  description   String
  // Item de serviço = snapshot de Service.price no ato da captura (FR-002).
  amount        Decimal @db.Decimal(10, 2)

  ledgerEntry LedgerEntry        @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id])
}
